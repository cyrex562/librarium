{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Librarium",
  "version": "0.100.0",
  "identifier": "com.librarium.app",
  "build": {
    "frontendDist": "./loading"
  },
  "app": {
    "windows": [
      {
        "title": "Librarium",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-yellow.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon-32x32.png",
      "icons/icon-128x128.png",
      "icons/icon.ico"
    ],
    "targets": ["deb", "appimage", "nsis", "dmg"],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "category": "Utility",
    "shortDescription": "A local-first markdown knowledge base",
    "longDescription": "Librarium is an offline-first, self-hosted markdown knowledge base with full-text search, entity relationships, and multi-user support."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["librarium"]
      }
    }
  }
}
